# Terraform-generated directories
.terraform/
.terraform.lock.hcl

# Terraform state files (may contain sensitive data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Local override files (optional, if used)
override.tf
override.tf.json
*-override.tf
*-override.tf.json

# Variable definition files (if they contain sensitive values and are not meant for version control)
*.tfvars
*.tfvars.json

# Provider-specific files (if not managed by .terraform directory)
# For example, if you have local provider binaries outside of .terraform/
# provider_name_vX.Y.Z